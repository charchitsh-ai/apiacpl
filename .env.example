# AYKA Care Environment Variables
PROJECT_NAME="AYKA Care"
ENVIRONMENT="development"

# Database Configuration (Make sure to use asyncpg for async support)
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/ayka_care"

# JWT Auth Keys
JWT_SECRET_KEY="supersecretaccesskeyforaykacareproductiongradehealthcaresystem"
JWT_REFRESH_SECRET_KEY="supersecretrefreshkeyforaykacareproductiongradehealthcaresystem"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
OTP_EXPIRE_MINUTES=5

# CORS (Comma separated list or JSON string)
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:8000"
